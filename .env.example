# Example .env file for webview-testing
# Copy this to .env and fill in your values

# GitHub Personal Access Token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Optional: Branch to upload results to (default: main)
RESULTS_BRANCH=main

# Optional: Specific Android device ID (auto-detected if not set)
# Get via: adb devices
ANDROID_DEVICE_ID=

# Optional: Specific iOS device UDID (auto-detected if not set)
# Get via: xcrun simctl list devices
IOS_DEVICE_UDID=

# Optional: Package names (update if apps are renamed)
ANDROID_PACKAGE_NAME=com.example.caniandroidwebview
IOS_BUNDLE_ID=com.example.CanIWKWebView

# Optional: Test URL (default: https://collector.openwebdocs.org/)
TEST_URL=https://collector.openwebdocs.org/

# Optional: Appium server URL (default: http://localhost:4723)
APPIUM_SERVER=http://localhost:4723
